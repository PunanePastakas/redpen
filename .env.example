# RedPen local synthetic development
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=
CONVEX_DEPLOYMENT_REGION=eu-west-1
SITE_URL=http://localhost:3000

# Raw-file retention defaults
RAW_FILE_RETENTION_DAYS=14
DELETE_AFTER_SHARE_HOURS=24
ABANDONED_DRAFT_RETENTION_DAYS=30

# AI provider selection. Use openai, azure_openai, or mock.
REDPEN_AI_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.5

# Azure OpenAI support. Values are read by Convex backend actions; do not expose keys as NEXT_PUBLIC_*.
# Azure model variables are deployment names, not model IDs.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_ANALYSIS_DEPLOYMENT=
AZURE_OPENAI_TASK_MODEL_DEPLOYMENT=
AZURE_OPENAI_REGION=sweden-central
AZURE_OPENAI_DEPLOYMENT_TYPE=datazone_standard
AZURE_OPENAI_DATA_CONTROL_MODE=azure_no_training_store_false
AZURE_OPENAI_CONTENT_LOGGING_DISABLED=true

# Safety gates
REAL_STUDENT_PILOT_MODE=false
DPIA_DECISION_PATH=docs/compliance/DPIA-draft.md
RAW_FILE_PROXY_ENABLED=false
FRONTEND_RUNTIME_REGION=eu-west-1
