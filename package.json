  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "next dev",
    "dev:convex": "convex dev",
    "setup:auth": "auth",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:fixtures": "tsx scripts/scan-real-student-data.ts",
    "test:ai-contracts": "vitest run tests/ai-schemas.test.ts tests/openai-provider.test.ts",
    "test:retention": "vitest run tests/retention-policy.test.ts",
    "test:config": "vitest run tests/config.test.ts",
    "check:config": "tsx scripts/check-config.ts",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build && pnpm run test:fixtures"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.92",
    "@excalidraw/excalidraw": "^0.18.1",
    "@tailwindcss/postcss": "^4.3.0",
    "convex": "^1.39.1",
    "katex": "^0.16.47",
    "lucide-react": "^0.555.0",
    "next": "^16.2.6",
    "openai": "^6.38.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "overrides": {
    "lodash-es": "^4.18.1",
    "nanoid": "^5.1.11",
    "postcss": "^8.5.15",
    "ws": "^8.20.1"
